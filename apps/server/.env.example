# apps/server environment variables (placeholders only — do not commit secrets)

# Render injects PORT automatically. Do not hardcode PORT on Render.
# Local development only:
# PORT=4000

NODE_ENV=production

# Required in production. Comma-separated browser origins allowed.
# Production Vercel frontend:
# CORS_ORIGIN=https://kouppi-web-nektarios-is-projects.vercel.app
# Optional local dev UI (comma-separated):
# CORS_ORIGIN=https://kouppi-web-nektarios-is-projects.vercel.app,http://localhost:3000
CORS_ORIGIN=https://your-frontend.vercel.app

# Required in production. Generate locally; enter only in Render dashboard.
JWT_SECRET=replace-with-long-random-secret

# --- FREE Render Web Service (no persistent disk) ---
# Ephemeral SQLite — wiped on restart/redeploy. Demo/testing only; NOT for real Career data.
DATABASE_PATH=/tmp/kouppi.db

# --- PAID persistent host (Render disk mount at /var/data) ---
# DATABASE_PATH=/var/data/kouppi.sqlite

# Optional: Redis for multi-instance Socket.IO + shared room store (not available on free tier by default).
# REDIS_URL=redis://default:password@host:6379

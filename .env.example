# KOUPPI environment variables (placeholders only — do not commit secrets)

# --- Vercel (apps/web) ---
# Public HTTPS origin of the deployed game server (apps/server). Required for multiplayer in production.
NEXT_PUBLIC_SERVER_URL=https://your-game-server.example.com

# Canonical public site URL for metadata/sitemap (optional; defaults to kouppi-web.vercel.app).
NEXT_PUBLIC_SITE_URL=https://your-frontend.vercel.app

# --- Game server (apps/server) — persistent host, NOT Vercel ---
# Render injects PORT on the host. Use PORT=4000 only for local development.
# PORT=4000

# Comma-separated allowed browser origins (your Vercel production + optional localhost).
CORS_ORIGIN=https://your-frontend.vercel.app

JWT_SECRET=replace-with-long-random-secret

# FREE Render Web Service (no disk): ephemeral demo database — NOT for real Career data.
# DATABASE_PATH=/tmp/kouppi.db

# PAID persistent host with mounted disk:
DATABASE_PATH=/var/data/kouppi.sqlite

# Optional: Redis for multi-instance Socket.IO + shared room store + friend presence.
# REDIS_URL=redis://default:password@host:6379

NODE_ENV=production
